# Backend configuration (optional overrides). Secrets/API keys are supplied
# per-request from the frontend UI and are never stored on the server.
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
MAX_ITERATIONS=1000
SANDBOX_TIMEOUT_SECONDS=3600
MAX_SEARCH_RESULTS=15
SEARCH_PROVIDER=tavily
FETCH_PROVIDER=firecrawl
